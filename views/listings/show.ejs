<% layout('layouts/boilerplate') %>

<!-- Tailwind CSS & Google Fonts -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "surface": "#fcf9f8",
                    "primary-fixed-dim": "#ffb2b6",
                    "on-surface-variant": "#5c3f41",
                    "on-tertiary-fixed-variant": "#464747",
                    "on-tertiary": "#ffffff",
                    "on-secondary-container": "#006e72",
                    "surface-container-highest": "#e5e2e1",
                    "on-primary-fixed-variant": "#920029",
                    "secondary-container": "#8eeff4",
                    "secondary": "#00696d",
                    "on-primary-container": "#fffbff",
                    "on-error-container": "#93000a",
                    "on-error": "#ffffff",
                    "surface-dim": "#dcd9d9",
                    "on-secondary": "#ffffff",
                    "background": "#fcf9f8",
                    "secondary-fixed": "#91f2f7",
                    "surface-container-low": "#f6f3f2",
                    "tertiary-fixed-dim": "#c7c6c6",
                    "on-surface": "#1b1c1c",
                    "surface-bright": "#fcf9f8",
                    "on-primary-fixed": "#40000d",
                    "outline": "#906f70",
                    "error-container": "#ffdad6",
                    "error": "#ba1a1a",
                    "primary": "#ba0036",
                    "surface-container": "#f0eded",
                    "on-primary": "#ffffff",
                    "surface-container-lowest": "#ffffff",
                    "surface-variant": "#e5e2e1",
                    "primary-fixed": "#ffdada",
                    "surface-container-high": "#eae7e7",
                    "outline-variant": "#e5bdbe",
                    "inverse-on-surface": "#f3f0ef",
                    "tertiary": "#5c5c5c",
                    "surface-tint": "#be0038",
                    "tertiary-container": "#747474",
                    "inverse-surface": "#303030",
                    "on-tertiary-fixed": "#1b1c1c",
                    "inverse-primary": "#ffb2b6",
                    "tertiary-fixed": "#e3e2e2",
                    "on-background": "#1b1c1c",
                    "on-secondary-fixed-variant": "#004f52",
                    "on-tertiary-container": "#fefcfc",
                    "on-secondary-fixed": "#002021",
                    "primary-container": "#e21e4a",
                    "secondary-fixed-dim": "#74d6db"
                },
                fontFamily: {
                    "headline": ["Plus Jakarta Sans", "sans-serif"],
                    "body": ["Plus Jakarta Sans", "sans-serif"],
                    "label": ["Plus Jakarta Sans", "sans-serif"]
                },
                borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
            },
        },
