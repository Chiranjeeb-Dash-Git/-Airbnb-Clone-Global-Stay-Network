            <div class="filter-item">
                <button type="button" class="filter-btn">
                    <div class="icon-wrapper">
                        <i class="bi bi-tree fs-5"></i>
                    </div>
                    <span class="filter-label">Treehouses</span>
                </button>
            </div>

