<% layout('layouts/boilerplate') %>
<style>
    .auth-bg {
        background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.55)),
                    url('https://images.unsplash.com/photo-1682687220742-aba13b6e50ba?q=80&w=2070') no-repeat center center fixed;
        background-size: cover;
        min-height: 100vh;
        display: flex;
        align-items: center;
        margin: 0;
        padding: 0;
        font-family: 'Arial', sans-serif;
    }

    .auth-shell {
        width: 100%;
        padding: 48px 0;
    }

    .auth-card {
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 22px;
        padding: 28px 26px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(10px);
    }

    .auth-title {
        color: #fff;
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: 1px;
        margin-bottom: 0.3rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.25);
        text-align: center;
    }

    .auth-subtitle {
        color: rgba(255,255,255,0.85);
        text-align: center;
        margin-bottom: 1.6rem;
        font-size: 0.95rem;
    }

    .field-label {
        color: rgba(255,255,255,0.95);
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-bottom: 0.4rem;
    }

    .auth-input {
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 12px;
        padding: 12px 14px;
        color: #fff;
        transition: all 0.25s ease;
    }

    .auth-input:focus {
        background: rgba(255, 255, 255, 0.18);
        border-color: rgba(255, 255, 255, 0.35);
        box-shadow: 0 0 0 4px rgba(255, 56, 92, 0.20);
        outline: none;
    }

    .auth-input::placeholder {
        color: rgba(255, 255, 255, 0.55);
    }

    .primary-btn {
        background: linear-gradient(45deg, #FF385C, #FF8E53);
        border: none;
        padding: 12px 18px;
        color: white;
        border-radius: 999px;
        font-weight: 800;
        letter-spacing: 0.8px;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        width: 100%;
        text-transform: uppercase;
    }

    .primary-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(255, 56, 92, 0.30);
    }

    .helper {
        color: rgba(255,255,255,0.85);
        text-align: center;
        margin-top: 14px;
        font-size: 0.95rem;
    }

    .helper a {
        color: #FF8E53;
        text-decoration: none;
        font-weight: 700;
    }

    .helper a:hover {
        text-decoration: underline;
    }

    .navbar.transparent {
        background-color: transparent !important;
        box-shadow: none !important;
        position: absolute;
        top: 0;
        width: 100%;
        z-index: 1000;
    }

    .navbar.transparent .navbar-brand,
    .navbar.transparent .nav-link {
        color: #fff !important;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
    }
</style>

<div class="auth-bg">
    <div class="auth-shell">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-7 col-lg-5">
                    <div class="auth-card">
                        <h1 class="auth-title">Welcome back</h1>
                        <p class="auth-subtitle">Log in to manage trips, favorites, and bookings.</p>

                        <form action="/login" method="post" class="needs-validation">
                            <div class="form-group mb-3">
                                <label class="field-label" for="username">Username</label>
                                <input
                                    type="text"
                                    class="form-control auth-input"
                                    id="username"
                                    name="username"
                                    required
                                    placeholder="Enter your username"
                                >
                            </div>

                            <div class="form-group mb-4">
                                <label class="field-label" for="password">Password</label>
                                <input
                                    type="password"
                                    class="form-control auth-input"
                                    id="password"
                                    name="password"
                                    required
                                    placeholder="Enter your password"
                                >
                            </div>

                            <div class="form-group">
                                <input class="primary-btn" type="submit" value="Log in">
                            </div>
                        </form>

                        <div class="helper">
                            Don't have an account?
                            <a href="/signup">Sign up</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>