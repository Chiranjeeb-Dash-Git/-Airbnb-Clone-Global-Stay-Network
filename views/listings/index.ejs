    }

    .search-icon-btn:hover {
        background: #d90b3e !important;
    }

    input#searchInput::placeholder {
        color: #717171 !important;
        font-weight: 400;
    }

    /* Filter Bar Styles */
    .filter-container {
        background: white;
        padding: 0 1rem !important;
        overflow-x: hidden;
        border-bottom: 1px solid #ebebeb;
    }

    .filter-scroll {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 8px;
    }

    .filter-item {
        flex: 0 0 auto;
        width: 80px;
        text-align: center;
    }

    .filter-btn {
        border: 0;
        background: transparent;
        padding: 0;
        width: 100%;
        cursor: pointer;
    }

    .icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #f7f7f7 !important;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px;
        transition: all 0.2s ease;
    }

    .filter-btn.active .icon-wrapper {
        background: #000000 !important;
    }

    .filter-btn.active .filter-label {
        color: #000000 !important;
    }

    .filter-label {
        font-size: 12px;
        color: #717171;
        font-weight: 500;
        display: block;
        white-space: nowrap;
        transition: color 0.2s ease;
    }

    .filter-btn:hover .icon-wrapper {
        background: #e6e6e6 !important;
    }

    .filter-btn:hover .filter-label {
        color: #000000 !important;
    }

    /* Updated Filter Bar Styles */
    .filter-scroll::-webkit-scrollbar {
        height: 3px;
        background: transparent;
    }

    .filter-scroll::-webkit-scrollbar-thumb {
        background: #cccccc;
    }

    .filter-item {
        width: auto;
        min-width: 80px;
    }

    .filter-label {
        font-size: 0.875rem;
        line-height: 1.25rem;
    }

    .icon-wrapper i {
        transition: transform 0.2s ease;
    }

    .filter-btn.active .icon-wrapper i {
        color: white !important;
    }

    .filter-btn:hover .icon-wrapper i {
        transform: scale(1.1);
    }

    /* Updated Color Scheme (Cleaned up) */

    /* Filter Bar Colors */
    .filter-btn.active .icon-wrapper {
        background: #000000 !important;
    }

    .filter-btn.active .filter-label {
        color: #000000 !important;
    }

    .filter-btn:hover .filter-label {
        color: #000000 !important;
    }

    .icon-wrapper {
        background: #f7f7f7 !important;
    }

    .filter-btn:hover .icon-wrapper {
        background: #e6e6e6 !important;
    }

    /* Scrollbar Color */
    .filter-scroll::-webkit-scrollbar-thumb {
        background: #cccccc;
    }

    /* Favorite Icon Color */
    .bi-heart-fill {
        color: #ff385c !important;
    }

    /* Final Color Fixes */
    .filter-btn .icon-wrapper i {
        color: #000000 !important; /* Force black icons */
    }

    .filter-btn.active .icon-wrapper {
        background: #000000 !important;
    }

    .filter-btn.active .icon-wrapper i {
        color: #ffffff !important; /* White icons on active */
    }

    .filter-btn:hover .icon-wrapper {
        background: #e6e6e6 !important;
    }

    /* Cleaned up duplicate search styles */

    .filter-scroll::-webkit-scrollbar-thumb {
        background: #888888;
    }

    /* Add these styles */
    .search-container {
        transition: opacity 0.3s ease;
    }

    #stickySearch {
        animation: slideDown 0.3s ease;
    }

    @keyframes slideDown {
        from { transform: translate(-50%, -20px); opacity: 0; }
        to { transform: translate(-50%, 0); opacity: 1; }
    }
</style>

